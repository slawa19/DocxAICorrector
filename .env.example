# ============================================================================
# DocxAICorrector — environment template. Copy to .env and fill in values.
#
# Almost every DOCX_AI_* / DOCXAI_* setting has a default in config.toml; only
# set the ones you need to override. Lines below show common overrides — most
# can be deleted if the defaults are fine. Keep secrets out of version control.
# ============================================================================

# --- Provider API keys ------------------------------------------------------
# OpenRouter — REQUIRED. Primary provider for openrouter:* selectors
# (translation via gemini, reader-cleanup post-pass via Claude).
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Anthropic — OPTIONAL. Only when a selector points directly at anthropic:*
# (e.g. reader-cleanup default). Not needed if Claude is routed via OpenRouter.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OpenAI — OPTIONAL. Only when gpt-* models are used directly (default text
# model and/or the image phase below).
OPENAI_API_KEY=your_openai_api_key_here

# --- Provider toggles -------------------------------------------------------
DOCX_AI_PROVIDERS_OPENROUTER_ENABLED=true
DOCX_AI_PROVIDERS_OPENAI_ENABLED=true
# DOCX_AI_PROVIDERS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DOCX_AI_PROVIDERS_OPENROUTER_REFERER=DocxAICorrector
# DOCX_AI_PROVIDERS_OPENROUTER_TITLE=DocxAICorrector

# --- Text / translation models ----------------------------------------------
DOCX_AI_MODELS_TEXT_DEFAULT=openrouter:google/gemini-3.1-flash-lite-preview
DOCX_AI_MODELS_TEXT_OPTIONS=gpt-5.4,gpt-5.4-mini,gpt-5-mini
DOCX_AI_CHUNK_SIZE=6000
DOCX_AI_MAX_RETRIES=3

# --- Reader-cleanup post-pass (semantic structure correction) ---------------
# Enable the AI reader-cleanup post-pass (off by default).
DOCX_AI_READER_CLEANUP_ENABLED=false
# Post-pass model. Empty = config.toml default (anthropic:claude-sonnet-4-6,
# needs ANTHROPIC_API_KEY). Cheaper Claude via OpenRouter (no Anthropic key):
#   openrouter:anthropic/claude-haiku-4.5
DOCX_AI_READER_CLEANUP_MODEL=

# --- Structure recognition / validation (optional) --------------------------
# Optional override. When omitted, structure recognition inherits DOCX_AI_MODELS_TEXT_DEFAULT.
# DOCX_AI_MODELS_STRUCTURE_RECOGNITION_DEFAULT=openrouter:google/gemini-3.1-flash-lite-preview
DOCX_AI_STRUCTURE_RECOGNITION_MODE=auto
DOCX_AI_STRUCTURE_VALIDATION_ENABLED=true
DOCX_AI_STRUCTURE_VALIDATION_MIN_PARAGRAPHS_FOR_AUTO_GATE=40
DOCX_AI_STRUCTURE_VALIDATION_MIN_EXPLICIT_HEADING_DENSITY=0.003
DOCX_AI_STRUCTURE_VALIDATION_MAX_SUSPICIOUS_SHORT_BODY_RATIO_WITHOUT_ESCALATION=0.05
DOCX_AI_STRUCTURE_VALIDATION_MAX_ALL_CAPS_OR_CENTERED_BODY_RATIO_WITHOUT_ESCALATION=0.03
DOCX_AI_STRUCTURE_VALIDATION_TOC_LIKE_SEQUENCE_MIN_LENGTH=4
DOCX_AI_STRUCTURE_VALIDATION_FORBID_HEADING_ONLY_COLLAPSE=true
DOCX_AI_STRUCTURE_VALIDATION_SAVE_DEBUG_ARTIFACTS=true

# --- Image phase models (optional; only when processing/redrawing images) ----
DOCX_AI_MODELS_IMAGE_ANALYSIS_DEFAULT=gpt-5.4-mini
DOCX_AI_MODELS_IMAGE_VALIDATION_DEFAULT=gpt-5.4-mini
DOCX_AI_MODELS_IMAGE_RECONSTRUCTION_DEFAULT=gpt-5.4-mini
DOCX_AI_MODELS_IMAGE_GENERATION_DEFAULT=gpt-image-1.5
DOCX_AI_MODELS_IMAGE_EDIT_DEFAULT=gpt-image-1.5
DOCX_AI_MODELS_IMAGE_GENERATION_VISION_DEFAULT=gpt-5.4-mini
