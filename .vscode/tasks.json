{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Setup Project",
			"type": "shell",
			"command": "${workspaceFolder}\\scripts\\setup-project.ps1",
			"options": {
				"cwd": "${workspaceFolder}",
				"shell": {
					"executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
					"args": [
						"-NoProfile",
						"-ExecutionPolicy",
						"Bypass",
						"-File"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "build"
		},
		{
			"label": "Start Project",
			"type": "shell",
			"command": "${workspaceFolder}\\scripts\\start-project.ps1",
			"options": {
				"cwd": "${workspaceFolder}",
				"shell": {
					"executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
					"args": [
						"-NoProfile",
						"-ExecutionPolicy",
						"Bypass",
						"-File"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"focus": false,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Stop Project",
			"type": "shell",
			"command": "${workspaceFolder}\\scripts\\stop-project.ps1",
			"options": {
				"cwd": "${workspaceFolder}",
				"shell": {
					"executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
					"args": [
						"-NoProfile",
						"-ExecutionPolicy",
						"Bypass",
						"-File"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"focus": false,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "none"
		},
		{
			"label": "Project Status",
			"type": "shell",
			"command": "${workspaceFolder}\\scripts\\status-project.ps1",
			"options": {
				"cwd": "${workspaceFolder}",
				"shell": {
					"executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
					"args": [
						"-NoProfile",
						"-ExecutionPolicy",
						"Bypass",
						"-File"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"focus": false,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "none"
		},
		{
			"label": "Tail Streamlit Log",
			"type": "shell",
			"command": "${workspaceFolder}\\scripts\\tail-streamlit-log.ps1",
			"args": [
				"-Lines",
				"${input:streamlitLogLines}"
			],
			"options": {
				"cwd": "${workspaceFolder}",
				"shell": {
					"executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
					"args": [
						"-NoProfile",
						"-ExecutionPolicy",
						"Bypass",
						"-File"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "none"
		},
		{
			"label": "Restart Project",
			"type": "shell",
			"command": "${workspaceFolder}\\scripts\\restart-project.ps1",
			"options": {
				"cwd": "${workspaceFolder}",
				"shell": {
					"executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
					"args": [
						"-NoProfile",
						"-ExecutionPolicy",
						"Bypass",
						"-File"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated",
				"focus": false,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "none"
		},
		{
			"label": "Run Full Pytest",
			"type": "shell",
			"command": "bash scripts/test.sh",
			"options": {
				"shell": {
					"executable": "wsl.exe",
					"args": [
						"-d",
						"Debian",
						"--cd",
						"${workspaceFolder}",
						"--"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "test"
		},
		{
			"label": "Run Current Test File",
			"type": "shell",
			"command": "bash scripts/test.sh \"${relativeFile}\"",
			"options": {
				"shell": {
					"executable": "wsl.exe",
					"args": [
						"-d",
						"Debian",
						"--cd",
						"${workspaceFolder}",
						"--"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "test"
		},
		{
			"label": "Run Current Test Node",
			"type": "shell",
			"command": "bash scripts/test.sh \"${relativeFile}::${input:pytestNodeSuffix}\"",
			"options": {
				"shell": {
					"executable": "wsl.exe",
					"args": [
						"-d",
						"Debian",
						"--cd",
						"${workspaceFolder}",
						"--"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "test"
		},
		{
			"label": "Run Docker CI Parity Pytest",
			"type": "shell",
			"command": "bash -lc 'docker run --rm -v \"$(pwd)\":/src -w /src python:3.12 bash -lc \"python -m venv /tmp/docxai-venv && . /tmp/docxai-venv/bin/activate && python -m pip install --upgrade pip && pip install -r requirements.txt && pytest tests/ -q\"'",
			"options": {
				"shell": {
					"executable": "wsl.exe",
					"args": [
						"-d",
						"Debian",
						"--cd",
						"${workspaceFolder}",
						"--"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "test"
		},
		{
			"label": "Run Lietaer Real Validation",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"export DOCXAI_REAL_DOCUMENT_PROFILE=lietaer-core; export DOCXAI_REAL_DOCUMENT_RUN_PROFILE=ui-parity-default; bash scripts/run-real-document-validation.sh"
			],
			"options": {
				"shell": {
					"executable": "wsl.exe",
					"args": [
						"-d",
						"Debian",
						"--cd",
						"${workspaceFolder}",
						"--"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "test"
		},
		{
			"label": "Run Lietaer Real Validation AI",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"export DOCXAI_REAL_DOCUMENT_PROFILE=lietaer-core; export DOCXAI_REAL_DOCUMENT_RUN_PROFILE=ui-parity-ai-default; bash scripts/run-real-document-validation.sh"
			],
			"options": {
				"shell": {
					"executable": "wsl.exe",
					"args": [
						"-d",
						"Debian",
						"--cd",
						"${workspaceFolder}",
						"--"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "test"
		},
		{
			"label": "Run Real Document Validation Profile",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"profile=\"$1\"; run_profile=\"$2\"; if [[ -n \"$profile\" ]]; then export DOCXAI_REAL_DOCUMENT_PROFILE=\"$profile\"; fi; if [[ -n \"$run_profile\" ]]; then export DOCXAI_REAL_DOCUMENT_RUN_PROFILE=\"$run_profile\"; fi; bash scripts/run-real-document-validation.sh",
				"_",
				"${input:realDocumentProfileId}",
				"${input:realDocumentRunProfileId}"
			],
			"options": {
				"shell": {
					"executable": "wsl.exe",
					"args": [
						"-d",
						"Debian",
						"--cd",
						"${workspaceFolder}",
						"--"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "test"
		},
		{
			"label": "Run Real Document Quality Gate",
			"type": "shell",
			"command": "bash scripts/run-real-document-quality-gate.sh",
			"options": {
				"shell": {
					"executable": "wsl.exe",
					"args": [
						"-d",
						"Debian",
						"--cd",
						"${workspaceFolder}",
						"--"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "test"
		},
		{
			"label": "Run Structural Preparation Diagnostic",
			"type": "shell",
			"command": "bash scripts/run-structural-preparation-diagnostic.sh \"${input:structuralDiagnosticDocumentProfileId}\" \"${input:structuralDiagnosticRunProfileArg}\"",
			"options": {
				"shell": {
					"executable": "wsl.exe",
					"args": [
						"-d",
						"Debian",
						"--cd",
						"${workspaceFolder}",
						"--"
					]
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": true,
				"clear": true,
				"showReuseMessage": false,
				"close": false
			},
			"group": "test"
		}
	],
	"inputs": [
		{
			"id": "pytestNodeSuffix",
			"type": "promptString",
			"description": "Pytest node suffix, e.g. test_name or TestClass::test_name"
		},
		{
			"id": "streamlitLogLines",
			"type": "promptString",
			"description": "Number of streamlit.log tail lines",
			"default": "80"
		},
		{
			"id": "realDocumentProfileId",
			"type": "promptString",
			"description": "Document profile id from corpus_registry.toml",
			"default": "lietaer-core"
		},
		{
			"id": "realDocumentRunProfileId",
			"type": "promptString",
			"description": "Optional run profile id from corpus_registry.toml",
			"default": ""
		},
		{
			"id": "structuralDiagnosticDocumentProfileId",
			"type": "promptString",
			"description": "Document profile id for structural preparation diagnostic",
			"default": "end-times-pdf-core"
		},
		{
			"id": "structuralDiagnosticRunProfileArg",
			"type": "promptString",
			"description": "Optional literal CLI arg, e.g. --run-profile-id structural-passthrough-default",
			"default": ""
		}
	]
}
